default_platform(:ios)

platform :ios do
  desc "Install App Store distribution cert + profile into the CI keychain (readonly in CI)"
  lane :certificates do
    setup_ci if is_ci
    match(type: "appstore", api_key: bootstrap_api_key, readonly: is_ci)
  end

  desc "Install Ad Hoc distribution cert + profile into the CI keychain (readonly in CI)"
  lane :adhoc_certificates do
    setup_ci if is_ci
    match(type: "adhoc", api_key: bootstrap_api_key, readonly: is_ci)
  end

  desc "Bootstrap: register App ID if missing, create distribution cert + App Store profile, push to match repo"
  lane :bootstrap do
    setup_ci if is_ci
    api_key = bootstrap_api_key
    register_app_id_if_missing(api_key)
    match(type: "appstore", api_key: api_key, readonly: false)
  end

  desc "Bootstrap: force-recreate the App Store provisioning profile"
  lane :bootstrap_force do
    setup_ci if is_ci
    api_key = bootstrap_api_key
    register_app_id_if_missing(api_key)
    match(type: "appstore", api_key: api_key, readonly: false, force: true)
  end

  desc "Bootstrap: force-recreate BOTH the distribution cert and the profile (use when the match repo is missing a .cer)"
  lane :bootstrap_force_certs do
    setup_ci if is_ci
    api_key = bootstrap_api_key
    register_app_id_if_missing(api_key)
    match(
      type: "appstore",
      api_key: api_key,
      readonly: false,
      force: true,
      force_for_new_certificates: true
    )
  end

  # Idempotent App ID registration on the Apple Developer Portal via the
  # App Store Connect API. `produce` only supports Apple ID username/password
  # auth, so we drop down to Spaceship::ConnectAPI directly — this honors the
  # API key set up by `app_store_connect_api_key`.
  def register_app_id_if_missing(api_key)
    Spaceship::ConnectAPI.token = Spaceship::ConnectAPI::Token.create(**api_key)
    bundle_id = "com.chaos.arena"
    existing = Spaceship::ConnectAPI::BundleId.all.find { |b| b.identifier == bundle_id }
    if existing
      UI.message("App ID '#{bundle_id}' already exists, skipping registration.")
    else
      Spaceship::ConnectAPI::BundleId.create(
        name: "Chaos Arena",
        identifier: bundle_id,
        platform: "IOS"
      )
      UI.success("Registered App ID '#{bundle_id}' on the Apple Developer Portal.")
    end
  end

  # Idempotent App Store Connect app record creation. Required before the
  # first TestFlight / App Store upload — `pilot` will fail with "Could not
  # find app with bundle id" otherwise. Same trick as above: `produce` doesn't
  # accept an api_key, so use Spaceship directly.
  def register_app_in_app_store_connect_if_missing(api_key)
    Spaceship::ConnectAPI.token = Spaceship::ConnectAPI::Token.create(**api_key)
    bundle_id = "com.chaos.arena"
    existing = Spaceship::ConnectAPI::App.find(bundle_id)
    if existing
      UI.message("App '#{bundle_id}' already exists in App Store Connect, skipping.")
    else
      Spaceship::ConnectAPI::App.create(
        name: "Chaos Arena",
        primary_locale: "en-US",
        bundle_id: bundle_id,
        sku: "chaos-arena",
        platforms: ["IOS"]
      )
      UI.success("Created app '#{bundle_id}' in App Store Connect.")
    end
  end

  desc "Destructive: revoke the App Store distribution cert + profile for this team"
  lane :nuke_distribution do
    setup_ci if is_ci
    # setup_ci forces MATCH_READONLY=true; match_nuke needs write access to
    # actually revoke + delete, so override for this lane only.
    ENV["MATCH_READONLY"] = "false"
    match_nuke(type: "appstore", api_key: bootstrap_api_key, skip_confirmation: true)
  end

  # ── Ad Hoc signing (sideload-installable IPAs for specific devices) ───────

  desc "Bootstrap: create Ad Hoc cert + profile listing all registered devices, push to match repo"
  lane :bootstrap_adhoc do
    setup_ci if is_ci
    api_key = bootstrap_api_key
    register_app_id_if_missing(api_key)
    # force_for_new_devices regenerates the profile whenever new device UDIDs
    # are registered in the Apple team, so re-running this lane after adding
    # a device is enough to pick it up.
    match(
      type: "adhoc",
      api_key: api_key,
      readonly: false,
      force_for_new_devices: true
    )
  end

  desc "Bootstrap: force-recreate BOTH the Ad Hoc cert and the profile (use when the match repo is missing the ad-hoc .cer)"
  lane :bootstrap_adhoc_force_certs do
    setup_ci if is_ci
    api_key = bootstrap_api_key
    register_app_id_if_missing(api_key)
    match(
      type: "adhoc",
      api_key: api_key,
      readonly: false,
      force: true,
      force_for_new_certificates: true,
      force_for_new_devices: true
    )
  end

  desc "Destructive: revoke the Ad Hoc cert + profile for this team"
  lane :nuke_adhoc do
    setup_ci if is_ci
    ENV["MATCH_READONLY"] = "false"
    match_nuke(type: "adhoc", api_key: bootstrap_api_key, skip_confirmation: true)
  end

  desc "Upload a built IPA to TestFlight via the App Store Connect API"
  lane :upload_testflight do |options|
    ipa_path = options[:ipa] || ENV.fetch("IPA_PATH")
    changelog = options[:changelog] || ENV["TESTFLIGHT_CHANGELOG"]
    api_key = bootstrap_api_key
    register_app_in_app_store_connect_if_missing(api_key)
    upload_to_testflight(
      api_key: api_key,
      ipa: ipa_path,
      changelog: changelog,
      # Skip waiting for Apple's processing — CI doesn't need to block on it.
      # TestFlight notifies testers once processing finishes server-side.
      skip_waiting_for_build_processing: true,
      # Don't auto-distribute to external groups — internal testers only by default.
      distribute_external: false,
      # If this is the first build for the app, skip the compliance question
      # instead of aborting (can be overridden via ENV if needed).
      skip_submission: false
    )
  end

  private_lane :bootstrap_api_key do
    app_store_connect_api_key(
      key_id: ENV.fetch("APP_STORE_CONNECT_API_KEY_KEY_ID"),
      issuer_id: ENV.fetch("APP_STORE_CONNECT_API_KEY_ISSUER_ID"),
      key_content: ENV.fetch("APP_STORE_CONNECT_API_KEY_KEY"),
      is_key_content_base64: true,
      in_house: false
    )
  end
end
