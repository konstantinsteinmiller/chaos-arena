<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
          xmlns:tools="http://schemas.android.com/tools"
          package="com.plugin.levelplay">

  <uses-sdk android:minSdkVersion="24"/>

  <!-- LevelPlay network fetches and connectivity probes. -->
  <uses-permission android:name="android.permission.INTERNET"/>
  <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE"/>

  <!--
  COPPA / Google Play Families Policy: every advertising-identifier
  permission introduced by the Google Mobile Ads / LevelPlay stack
  must be explicitly removed via manifest merger on a kids app.
  These overrides win over the transitive declarations pulled in by
  play-services-ads, the LevelPlay mediation SDK, and any bundled
  adapter (AdMob, Meta AN, AppLovin, etc.).

  If any of these lines is removed, Google Play will flag the app
  for a Families Policy violation and block publishing.

  • AD_ID — classic Google Play Services advertising identifier.
  • ACCESS_ADSERVICES_AD_ID — Android 13+ Privacy Sandbox ad ID.
  • ACCESS_ADSERVICES_ATTRIBUTION / _TOPICS — Privacy Sandbox
    interest-based / attribution APIs. Prohibited on kids apps.
  -->
  <uses-permission
    android:name="com.google.android.gms.permission.AD_ID"
    tools:node="remove"/>
  <uses-permission
    android:name="android.permission.ACCESS_ADSERVICES_AD_ID"
    tools:node="remove"/>
  <uses-permission
    android:name="android.permission.ACCESS_ADSERVICES_ATTRIBUTION"
    tools:node="remove"/>
  <uses-permission
    android:name="android.permission.ACCESS_ADSERVICES_TOPICS"
    tools:node="remove"/>
  <!--
  Required by play-services-ads / AdMob: the SDK ships a
  `MobileAdsInitProvider` ContentProvider that auto-registers from
  the AdMob library's manifest and runs at process startup. It
  crashes the whole app if it can't find this meta-data tag, even
  when AdMob is not the winning bidder in the LevelPlay waterfall.

  The actual value is injected at build time via the manifest
  placeholder `admobAppId`, defined in the consuming app's
  build.gradle.kts and sourced from the `VITE_APP_ADMOB_ANDROID_APP_ID`
  env var (see .env.tauri). When unset, the fallback is Google's
  documented AdMob test app ID — benign, returns a static "Test Ad"
  placeholder, no account required.

  Format reminder: AdMob App ID uses TILDE (`~`) as separator.
  A value with a slash (`/`) is an *ad unit* ID — wrong tag.
  -->
  <application>
    <meta-data
      android:name="com.google.android.gms.ads.APPLICATION_ID"
      android:value="dollar_openBracket_admobAppId_closeBracket"/>
  </application>

</manifest>