{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Chaos Arena",
  "version": "1.0.1",
  "identifier": "com.chaos.arena",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build-only"
  },
  "app": {
    "windows": [
      {
        "title": "Chaos Arena",
        "width": 414,
        "height": 896,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "iOS": {
      "minimumSystemVersion": "16.0"
    }
  }
}
